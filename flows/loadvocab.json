        "python_code": "import pandas as pd\nimport numpy as np\n\ndef exec(myinput):\n  df = myinput[\"upload_cpt4\"].result\n\n  df[\"valid_start_date\"] = pd.to_datetime(df['valid_start_date'], format='%Y%m%d')\n  df[\"valid_end_date\"] =  pd.to_datetime(df['valid_end_date'], format='%Y%m%d')\n\n  df['concept_name'] = df['concept_name'].fillna('NULL')\n\n  return df"
      },
